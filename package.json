{
  "name": "advanced-sales-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "cd backend && .\\venv\\Scripts\\uvicorn.exe main:app --reload --host 127.0.0.1 --port 8000",
    "db:import:postgres": "cd backend && .\\venv\\Scripts\\python.exe scripts\\import_json_to_postgres.py",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "testsprite:frontend": "npm run build && vite preview",
    "test:backend": "cd backend && .\\venv\\Scripts\\pytest.exe tests -v"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "docxtemplater": "^3.68.4",
